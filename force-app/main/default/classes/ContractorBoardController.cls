        Time__c t = new Time__c();
        t.Id      = timeId;
        if (hours != null) {
            t.Minutes_Logged__c = hours * 60;
        }
        t.Additional_Comments__c = description;
        Database.update(t, System.AccessLevel.SYSTEM_MODE);
    }

