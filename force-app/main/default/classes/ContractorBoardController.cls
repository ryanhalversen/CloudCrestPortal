    // ── Name Helpers ──────────────────────────────────────────────────────────

    // Returns true if a name looks like a system or auto-generated account:
    //   - Portal users auto-generated by Salesforce: "User1699470575175559722"
    //   - System/integration accounts that start with a lowercase letter: "automatedprocess"
    //   - Accounts that start with a digit or decimal: "cloud1.560577..."
    private static Boolean isAutoGeneratedName(String name) {
        if (String.isBlank(name)) return true;
        if (Pattern.matches('User\\d{5,}', name)) return true;
        String first = name.substring(0, 1);
        // lowercase-starting = system account (real people have capitalized names)
        if (first == first.toLowerCase() && first != first.toUpperCase()) return true;
        // digit-starting
        if (Pattern.matches('[0-9]', first)) return true;
        return false;
    }

    // ── Name Resolution Helper ────────────────────────────────────────────────
    // Relationship traversal (e.g. Owner.Name, CreatedBy.Name, Contact.Name on User)
    // does not work from Experience Cloud portal users even with WITH SYSTEM_MODE.
    // This helper does two separate direct-object queries so both work reliably:
    //   1. Query User to get Name + ContactId
    //   2. Query Contact directly to get the proper display name for portal users
    private static Map<Id, String> resolveDisplayNames(Set<Id> userIds) {
        Map<Id, String> nameMap = new Map<Id, String>();
        if (userIds == null || userIds.isEmpty()) return nameMap;

        Map<Id, Id> userToContactId = new Map<Id, Id>();
        for (User u : [SELECT Id, Name, ContactId FROM User WHERE Id IN :userIds WITH SYSTEM_MODE]) {
            nameMap.put(u.Id, u.Name);                      // default to User.Name
            if (u.ContactId != null) userToContactId.put(u.Id, u.ContactId);
        }

        if (!userToContactId.isEmpty()) {
            // Reverse map: contactId → userId so we can write back by userId
            Map<Id, Id> contactToUserId = new Map<Id, Id>();
            for (Id uid : userToContactId.keySet()) {
                contactToUserId.put(userToContactId.get(uid), uid);
            }
            Set<Id> contactIds = new Set<Id>(userToContactId.values());
            for (Contact c : [SELECT Id, Name FROM Contact WHERE Id IN :contactIds WITH SYSTEM_MODE]) {
                if (String.isNotBlank(c.Name)) {
                    nameMap.put(contactToUserId.get(c.Id), c.Name);
                }
            }
        }
        return nameMap;
    }

    // ── Read ──────────────────────────────────────────────────────────────────

    // Returns only projects where the running user has stories assigned to them
    @AuraEnabled(cacheable=true)
    public static List<Sprint__c> getProjectsForUser() {
        Id uid = [SELECT Id FROM User WHERE Id = :UserInfo.getUserId() WITH SYSTEM_MODE LIMIT 1].Id;
        Id contactId = [SELECT ContactId FROM User WHERE Id = :uid WITH SYSTEM_MODE LIMIT 1].ContactId;
        Set<Id> projIds = new Set<Id>();
        for (Case c : [
            SELECT Projects__c
            FROM   Case
            WHERE  Projects__c != null
            AND    (OwnerId = :uid OR Story_Support__c = :uid OR Support_Contact__c = :contactId)
            WITH SYSTEM_MODE
        ]) {
            projIds.add(c.Projects__c);
        }
        if (projIds.isEmpty()) return new List<Sprint__c>();
        return [
            SELECT Id, Name
            FROM   Sprint__c
            WHERE  Id IN :projIds
            WITH SYSTEM_MODE
            ORDER BY Name
        ];
    }

    @AuraEnabled(cacheable=true)
    public static List<StoryWrapper> getStories(String projectId) {
        Id uid = UserInfo.getUserId();
        Id contactId = [SELECT ContactId FROM User WHERE Id = :uid WITH SYSTEM_MODE LIMIT 1].ContactId;

        String q =
            'SELECT Id, CaseNumber, Subject, Description, Status, Priority, Type, ' +
            'Projects__c, Projects__r.Name, Epic__c, Epic__r.Name, ' +
            'Hours_Estimate_to_Complete__c, Actual_Hours_to_Complete__c, ' +
            'OwnerId, Story_Support__c, Support_Contact__c, Support_Contact__r.Name, CreatedDate, ' +
            'Solution__c, Components_to_Deploy__c, Q_A__c, Documentation__c, ' +
            'Closing_Comments__c, Department__c, ContactId, Contact.Name ' +
            'FROM Case ' +
            'WHERE Status NOT IN (\'Cancelled\') ' +
            'AND (OwnerId = \'' + uid + '\' OR Story_Support__c = \'' + uid + '\'' +
            (contactId != null ? ' OR Support_Contact__c = \'' + contactId + '\'' : '') + ') ';

        if (String.isNotBlank(projectId)) {
            q += 'AND Projects__c = \'' + String.escapeSingleQuotes(projectId) + '\' ';
        }
        q += 'ORDER BY CreatedDate DESC LIMIT 500';

        List<Case> cases = Database.query(q, System.AccessLevel.SYSTEM_MODE);

        Set<Id> ownerIds = new Set<Id>();
        for (Case c : cases) {
            if (c.OwnerId != null) ownerIds.add(c.OwnerId);
        }
        Map<Id, String> ownerNameMap = resolveDisplayNames(ownerIds);

        List<StoryWrapper> result = new List<StoryWrapper>();
        for (Case c : cases) {
            StoryWrapper w         = new StoryWrapper();
            w.id                   = c.Id;
            w.caseNumber           = c.CaseNumber;
            w.subject              = c.Subject;
            w.description          = c.Description;
            w.status               = c.Status;
            w.priority             = c.Priority;
            w.storyType            = c.Type;
            w.estHours             = c.Hours_Estimate_to_Complete__c;
            w.hoursLogged          = c.Actual_Hours_to_Complete__c;
            w.ownerId              = c.OwnerId;
            String resolvedOwner   = ownerNameMap.containsKey(c.OwnerId)
                                        ? ownerNameMap.get(c.OwnerId) : '';
            // If User.Name is auto-generated and no Contact was found via ContactId,
            // fall back to Support_Contact__r.Name (the contractor's Contact on the Case).
            if (isAutoGeneratedName(resolvedOwner)
                && c.Support_Contact__r != null
                && String.isNotBlank(c.Support_Contact__r.Name)) {
                resolvedOwner = c.Support_Contact__r.Name;
            }
            w.ownerName            = resolvedOwner;
            w.epicId               = c.Epic__c;
            w.epicName             = c.Epic__r    != null ? c.Epic__r.Name    : '';
            w.projectId            = c.Projects__c;
            w.projectName          = c.Projects__r != null ? c.Projects__r.Name : '';
            w.createdDate          = c.CreatedDate;
            w.solution             = c.Solution__c;
            w.componentsToDeploy   = c.Components_to_Deploy__c;
            w.qa                   = c.Q_A__c;
            w.documentation        = c.Documentation__c;
            w.department           = c.Department__c;
            w.contactId            = c.ContactId;
            w.contactName          = c.Contact != null ? c.Contact.Name : '';
            w.closingComments      = c.Closing_Comments__c;
            result.add(w);
        }
        return result;
    }

    @AuraEnabled(cacheable=true)
    public static List<Time__c> getTimeEntries(String caseId) {
        return [
            SELECT Id, Minutes_Logged__c, Additional_Comments__c,
                   Logged_Date__c, CreatedBy.Name
            FROM   Time__c
            WHERE  Case__c = :caseId
            WITH SYSTEM_MODE
            ORDER BY Logged_Date__c DESC, CreatedDate DESC
            LIMIT 100
        ];
    }

    @AuraEnabled(cacheable=true)
    public static List<CaseComment> getNextSteps(String caseId) {
        return [
            SELECT Id, CommentBody, CreatedDate, CreatedBy.Name
            FROM   CaseComment
            WHERE  ParentId = :caseId
            WITH SYSTEM_MODE
            ORDER BY CreatedDate ASC
            LIMIT 200
        ];
    }

    @AuraEnabled(cacheable=true)
    public static List<ChatMessageWrapper> getChatMessages(String caseId) {
        Id uid = UserInfo.getUserId();
        List<FeedItem> items = [
            SELECT Id, Body, CreatedById, CreatedDate
            FROM   FeedItem
            WHERE  ParentId = :caseId
            AND    Type     = 'TextPost'
            WITH SYSTEM_MODE
            ORDER BY CreatedDate ASC
            LIMIT 200
        ];

        // Resolve author display names via two-query helper (portal users have
        // auto-generated User.Name; their real name lives on their Contact record).
        Set<Id> creatorIds = new Set<Id>();
        for (FeedItem fi : items) { creatorIds.add(fi.CreatedById); }
        Map<Id, String> nameMap = resolveDisplayNames(creatorIds);

        List<ChatMessageWrapper> result = new List<ChatMessageWrapper>();
        for (FeedItem fi : items) {
            ChatMessageWrapper w = new ChatMessageWrapper();
            w.id          = fi.Id;
            w.authorName  = nameMap.containsKey(fi.CreatedById)
                                ? nameMap.get(fi.CreatedById) : '';
            w.body        = fi.Body != null ? fi.Body : '';
            w.createdDate = fi.CreatedDate != null
                ? fi.CreatedDate.format('M/d h:mm a')
                : '';
            w.isMine = (fi.CreatedById == uid);
            result.add(w);
        }
        return result;
    }

    @AuraEnabled(cacheable=false)
    public static List<AttachmentWrapper> getAttachments(String caseId) {
        List<AttachmentWrapper> result = new List<AttachmentWrapper>();
        for (ContentDocumentLink l : [
            SELECT ContentDocumentId,
                   ContentDocument.Title,
                   ContentDocument.FileExtension,
                   ContentDocument.ContentSize,
                   ContentDocument.LatestPublishedVersionId
            FROM   ContentDocumentLink
            WHERE  LinkedEntityId = :caseId
            WITH SYSTEM_MODE
            ORDER BY ContentDocument.CreatedDate DESC
        ]) {
            AttachmentWrapper w = new AttachmentWrapper();
            w.contentDocumentId  = l.ContentDocumentId;
            w.title              = l.ContentDocument.Title;
            w.fileExtension      = l.ContentDocument.FileExtension;
            w.contentSize        = l.ContentDocument.ContentSize;
            w.contentVersionId   = l.ContentDocument.LatestPublishedVersionId;
            w.downloadUrl        = '/sfc/servlet.shepherd/document/download/' + l.ContentDocumentId;
            result.add(w);
        }
        return result;
    }

    @AuraEnabled(cacheable=false)
    public static List<UserOption> searchUsers(String searchTerm) {
        // Standard UserType = internal Salesforce users only (excludes portal/community/guest users)
        String term = String.isBlank(searchTerm) ? '%' : '%' + searchTerm + '%';
        List<UserOption> opts = new List<UserOption>();
        for (User u : [
            SELECT Id, Name, FirstName, LastName
            FROM   User
            WHERE  IsActive = true
            AND    UserType = 'Standard'
            AND    Name LIKE :term
            WITH SYSTEM_MODE
            ORDER BY Name
            LIMIT 50
        ]) {
            // Skip auto-generated system usernames (e.g. "User1699439307773342984")
            if (isAutoGeneratedName(u.Name)) continue;
            // Build full name from FirstName + LastName to avoid partial-name entries
            String displayName = '';
            if (String.isNotBlank(u.FirstName)) displayName += u.FirstName.trim();
            if (String.isNotBlank(u.LastName))  displayName += (displayName.length() > 0 ? ' ' : '') + u.LastName.trim();
            if (String.isBlank(displayName))    displayName = u.Name;
            UserOption o = new UserOption();
            o.id   = u.Id;
            o.name = displayName;
            opts.add(o);
            if (opts.size() == 20) break;
        }
        return opts;
    }

    @AuraEnabled(cacheable=true)
    public static List<Contact> getContactsForProject(String projectId) {
        if (String.isBlank(projectId)) return new List<Contact>();
        List<Sprint__c> sprints = [
            SELECT Accountlu__c
            FROM   Sprint__c
            WHERE  Id = :projectId
            WITH SYSTEM_MODE
            LIMIT 1
        ];
        if (sprints.isEmpty() || sprints[0].Accountlu__c == null) return new List<Contact>();
        Id accountId = sprints[0].Accountlu__c;
        return [
            SELECT Id, Name, Title
            FROM   Contact
            WHERE  AccountId = :accountId
            WITH SYSTEM_MODE
            ORDER BY Name
            LIMIT 50
        ];
    }

